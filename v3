                    explicacao: `A matéria pode se apresentar em três estados físicos principais: sólido, líquido e gasoso.
        - Sólido: partículas muito próximas, forma e volume definidos.
        - Líquido: partículas mais afastadas, volume definido, forma variável.
        - Gasoso: partículas muito afastadas, volume e forma variáveis.

        As mudanças de estado (fusão, vaporização, etc.) são cobradas no ENEM.`,
                    exercicio: {
                        pergunta: "Qual é o estado físico da água a 100°C ao nível do mar?",
                        alternativas: ["a) Sólido", "b) Líquido", "c) Gasoso", "d) Plasma"],
                        respostaCorreta: 2,
                        explicacao: "A 100°C a água entra em ebulição e passa para o estado gasoso (vapor). Portanto, a alternativa correta é c) Gasoso."
                    }
                },
                intermediario: {
                    titulo: "⚗️ Balanceamento de equações químicas",
                    explicacao: `Balancear uma equação química é garantir que o número de átomos de cada elemento seja igual nos reagentes e produtos.

        Exemplo: H₂ + O₂ → H₂O
        Desbalanceada. Para balancear: 2H₂ + O₂ → 2H₂O (agora temos 4 H e 2 O de cada lado).`,
                    exercicio: {
                        pergunta: "Qual é o coeficiente do oxigênio (O₂) na equação balanceada: Fe + O₂ → Fe₂O₃?",
                        alternativas: ["a) 1", "b) 2", "c) 3", "d) 4"],
                        respostaCorreta: 2,
                        explicacao: "A equação balanceada é: 4Fe + 3O₂ → 2Fe₂O₃. Portanto, o coeficiente do O₂ é 3."
                    }
                },
                avancado: {
                    titulo: "🔬 Química orgânica – Petróleo e plásticos",
                    explicacao: `O petróleo é uma mistura de hidrocarbonetos, formado por restos de seres vivos ao longo de milhões de anos. A destilação fracionada separa seus componentes (gasolina, diesel, etc.).

        Plásticos são polímeros sintéticos derivados do petróleo. O ENEM costuma abordar impactos ambientais e alternativas sustentáveis.`,
                    exercicio: {
                        pergunta: "Qual é a principal fonte de obtenção do plástico?",
                        alternativas: ["a) Carvão mineral", "b) Petróleo", "c) Gás natural", "d) Biomassa"],
                        respostaCorreta: 1,
                        explicacao: "A maioria dos plásticos é derivada do petróleo, através de processos petroquímicos."
                    }
                },
                redacao: {
                    titulo: "✍️ Química e sustentabilidade na redação",
                    explicacao: `Temas como poluição, efeito estufa e desenvolvimento sustentável são frequentes. Use conceitos como "química verde" e "pegada de carbono" para embasar seus argumentos.

        Exemplo: "A produção de plástico descartável contribui para a poluição dos oceanos, sendo necessário investir em bioplásticos e reciclagem."`,
                    exercicio: {
                        pergunta: "Qual das ações abaixo é um exemplo de química verde?",
                        alternativas: [
                            "a) Utilizar solventes tóxicos",
                            "b) Gerar resíduos não recicláveis",
                            "c) Desenvolver catalisadores mais eficientes",
                            "d) Aumentar o consumo de energia"
                        ],
                        respostaCorreta: 2,
                        explicacao: "A química verde busca processos mais limpos e eficientes. Desenvolver catalisadores que reduzam o consumo de energia e resíduos é um exemplo."
                    }
                }
            }
        };

        // ================================================================
        //  ESTADO DA APLICAÇÃO
        // ================================================================
        const state = {
            loggedIn: false,
            selectedSubjects: [], // nomes das matérias
            totalMinutes: 30,
            completed: new Set(), // nomes das matérias concluídas
            currentSchedule: [], // [{name, minutes}]
        };

        // ================================================================
        //  FUNÇÕES AUXILIARES
        // ================================================================
        function getMaxSubjects(minutes) {
            if (minutes <= 60) return 2;
            if (minutes <= 120) return 3;
            return 4;
        }

        function getLevelFromTime(minutes) {
            if (minutes <= 60) return "basico";
            if (minutes <= 120) return "intermediario";
            if (minutes <= 180) return "avancado";
            return "redacao";
        }

        function getLevelName(minutes) {
            const map = {
                basico: "📘 Básico",
                intermediario: "📙 Intermediário",
                avancado: "📗 Avançado",
                redacao: "✍️ Redação ENEM"
            };
            return map[getLevelFromTime(minutes)];
        }

        function getLevelColor(minutes) {
            const map = {
                basico: "#10B981",
                intermediario: "#F59E0B",
                avancado: "#EF4444",
                redacao: "#8B5CF6"
            };
            return map[getLevelFromTime(minutes)];
        }

        function formatTime(minutes) {
            const h = Math.floor(minutes / 60);
            const m = minutes % 60;
            if (h > 0) return `${h}h${m > 0 ? ` ${m}min` : ''}`;
            return `${m} min`;
        }

        // ================================================================
        //  LOGIN
        // ================================================================
        function login(e) {
            e.preventDefault();
            const user = document.getElementById('username').value.trim();
            const pass = document.getElementById('password').value.trim();
            if (user && pass) {
                state.loggedIn = true;
                document.getElementById('login-page').classList.add('hidden');
                document.getElementById('selection-page').classList.remove('hidden');
                renderSelection();
            } else {
                document.getElementById('login-error').style.display = 'block';
            }
        }

        // ================================================================
        //  SELEÇÃO DE MATÉRIAS E TEMPO
        // ================================================================
        function renderSelection() {
            const grid = document.getElementById('subjects-grid');
            const subjects = ['Matemática', 'Português', 'História', 'Química'];
            grid.innerHTML = '';
            subjects.forEach(name => {
                const div = document.createElement('div');
                div.className = 'subject-check';
                const checked = state.selectedSubjects.includes(name) ? 'checked' : '';
                div.innerHTML = `
                    <input type="checkbox" id="chk-${name}" value="${name}" ${checked}>
                    <label for="chk-${name}">${name}</label>
                `;
                div.addEventListener('click', (e) => {
                    // evitar duplo clique no checkbox
                    if (e.target.tagName !== 'INPUT') {
                        const cb = div.querySelector('input[type="checkbox"]');
                        cb.checked = !cb.checked;
                        updateSelection();
                    }
                });
                const cb = div.querySelector('input[type="checkbox"]');
                cb.addEventListener('change', updateSelection);
                grid.appendChild(div);
            });
            updateSelectionUI();
            updateTimeDisplay();
        }

        function updateSelection() {
            const checkboxes = document.querySelectorAll('#subjects-grid input[type="checkbox"]');
            const selected = [];
            checkboxes.forEach(cb => {
                if (cb.checked) selected.push(cb.value);
            });
            state.selectedSubjects = selected;
            updateSelectionUI();
        }

        function updateSelectionUI() {
            const max = getMaxSubjects(state.totalMinutes);
            document.getElementById('max-subjects-label').textContent = max;

            const checkboxes = document.querySelectorAll('#subjects-grid input[type="checkbox"]');
            checkboxes.forEach(cb => {
                const div = cb.closest('.subject-check');
                if (state.selectedSubjects.includes(cb.value)) {
                    div.classList.add('selected');
                } else {
                    div.classList.remove('selected');
                }
            });

            const warning = document.getElementById('limit-warning');
            if (state.selectedSubjects.length > max) {
                warning.style.display = 'block';
                // desabilitar checkboxes extras (mas já estão selecionados, então vamos desmarcar os excedentes)
                const extra = state.selectedSubjects.slice(max);
                checkboxes.forEach(cb => {
                    if (extra.includes(cb.value)) {
                        cb.checked = false;
                        cb.closest('.subject-check').classList.remove('selected');
                    }
                });
                // atualiza state
                state.selectedSubjects = state.selectedSubjects.slice(0, max);
            } else {
                warning.style.display = 'none';
            }
        }

        function adjustTime(delta) {
            let newTime = state.totalMinutes + delta;
            if (newTime < 30) newTime = 30;
            if (newTime > 240) newTime = 240;
            state.totalMinutes = newTime;
            updateTimeDisplay();
            updateSelectionUI(); // atualiza limite
        }

        function setTime(minutes) {
            state.totalMinutes = Math.min(240, Math.max(30, minutes));
            updateTimeDisplay();
            updateSelectionUI();
        }

        function updateTimeDisplay() {
            document.getElementById('total-time-display').textContent = formatTime(state.totalMinutes);
        }

        function startStudy() {
            if (state.selectedSubjects.length === 0) {
                alert('Selecione pelo menos uma matéria!');
                return;
            }
            // Gerar cronograma
            const total = state.totalMinutes;
            const count = state.selectedSubjects.length;
            const perSubject = Math.floor(total / count);
            // ajustar para distribuir o restante (opcional)
            let remaining = total - perSubject * count;
            state.currentSchedule = state.selectedSubjects.map((name, i) => ({
                name,
                minutes: perSubject + (i < remaining ? 1 : 0)
            }));

            // Resetar completados
            state.completed = new Set();

            document.getElementById('selection-page').classList.add('hidden');
            document.getElementById('schedule-page').classList.remove('hidden');
            renderSchedule();
        }

        function goBackToSelection() {
            document.getElementById('schedule-page').classList.add('hidden');
            document.getElementById('selection-page').classList.remove('hidden');
            renderSelection();
        }

        // ================================================================
        //  CRONOGRAMA
        // ================================================================
        function renderSchedule() {
            const list = document.getElementById('schedule-list');
            list.innerHTML = '';
            state.currentSchedule.forEach(item => {
                const li = document.createElement('li');
                li.className = 'schedule-item';
                if (state.completed.has(item.name)) li.classList.add('completed');

                const icon = item.name === 'Matemática' ? '📐' :
                    item.name === 'Português' ? '📖' :
                    item.name === 'História' ? '🏛️' : '🧪';

                li.innerHTML = `
                    <div class="subject-info">
                        <span>${icon}</span>
                        <span>${item.name}</span>
                        <span class="time-badge">${item.minutes} min</span>
                    </div>
                    <button class="check-mark" onclick="toggleComplete('${item.name}')">
                        ${state.completed.has(item.name) ? '✅' : '⬜'}
                    </button>
                `;
                li.addEventListener('click', (e) => {
                    if (e.target.tagName !== 'BUTTON') {
                        openModal(item.name, item.minutes);
                    }
                });
                list.appendChild(li);
            });

            updateProgress();
        }

        function toggleComplete(name) {
            if (state.completed.has(name)) {
                state.completed.delete(name);
            } else {
                state.completed.add(name);
            }
            renderSchedule();
        }

        function updateProgress() {
            const total = state.currentSchedule.length;
            const done = state.completed.size;
            const pct = total > 0 ? Math.round((done / total) * 100) : 0;
            document.getElementById('progress-fill').style.width = pct + '%';
            document.getElementById('progress-text').textContent =
                done === 0 ? 'Nenhuma matéria concluída' :
                done === total ? '🎉 Todas concluídas! Parabéns!' :
                `${done} de ${total} matérias concluídas (${pct}%)`;
            document.getElementById('completed-count').textContent = done;
            document.getElementById('total-subjects').textContent = total;
        }

        // ================================================================
        //  MODAL - CONTEÚDO
        // ================================================================
        function openModal(subjectName, minutes) {
            const level = getLevelFromTime(state.totalMinutes);
            const data = contentDB[subjectName]?.[level];
            if (!data) {
                alert('Conteúdo não encontrado para este nível.');
                return;
            }

            document.getElementById('modal-title').textContent = `${subjectName} – ${data.titulo}`;
            document.getElementById('modal-time-info').textContent = `⏱️ ${formatTime(minutes)}`;
            document.getElementById('modal-level-info').textContent = `📊 ${getLevelName(state.totalMinutes)}`;

            const container = document.getElementById('modal-content-dynamic');

            // Explicação
            let html = `<div class="explicacao">${data.explicacao}</div>`;

            // Exercício
            const ex = data.exercicio;
            if (ex) {
                const alternativasHtml = ex.alternativas.map((alt, idx) => `
                    <label>
                        <input type="radio" name="exercicio" value="${idx}">
                        ${alt}
                    </label>
                `).join('');

                html += `
                    <div class="exercicio-box">
                        <div class="pergunta">❓ ${ex.pergunta}</div>
                        <div class="alternativas">${alternativasHtml}</div>
                        <button onclick="verificarResposta(this, ${ex.respostaCorreta})" style="margin-top:8px;">Verificar resposta</button>
                        <div class="resposta" id="resposta-exercicio">
                            <strong>✅ Resposta correta:</strong> ${ex.alternativas[ex.respostaCorreta]}
                            <div class="explicacao-resposta">${ex.explicacao}</div>
                        </div>
                    </div>
                `;
            }

            container.innerHTML = html;

            // Link YouTube
            const videoLink = document.getElementById('modal-video-link');
            const baseYoutube = {
                'Matemática': 'https://www.youtube.com/results?search_query=matematica+enem',
                'Português': 'https://www.youtube.com/results?search_query=portugues+enem',
                'História': 'https://www.youtube.com/results?search_query=historia+enem',
                'Química': 'https://www.youtube.com/results?search_query=quimica+enem'
            };
            const term = baseYoutube[subjectName] || 'https://www.youtube.com/results?search_query=enem';
            videoLink.href = term + '+' + level;

            document.getElementById('content-modal').style.display = 'flex';
        }

        function verificarResposta(btn, correta) {
            const box = btn.closest('.exercicio-box');
            const radios = box.querySelectorAll('input[name="exercicio"]');
            let selecionado = null;
            radios.forEach(r => {
                if (r.checked) selecionado = parseInt(r.value);
            });
            const respostaDiv = box.querySelector('.resposta');
            if (selecionado === null) {
                alert('Selecione uma alternativa primeiro.');
                return;
            }
            respostaDiv.classList.add('correta');
            // destacar a resposta correta
            const labels = box.querySelectorAll('.alternativas label');
            labels.forEach((label, idx) => {
                if (idx === correta) {
                    label.style.border = '2px solid var(--accent-green)';
                    label.style.background = '#F0FDF4';
                } else {
                    label.style.border = '1px solid #CBD5E1';
                    label.style.background = '#fff';
                }
                if (idx === selecionado && idx !== correta) {
                    label.style.border = '2px solid var(--accent-red)';
                    label.style.background = '#FEF2F2';
                }
            });
            // desabilitar radios
            radios.forEach(r => r.disabled = true);
            btn.disabled = true;
            btn.textContent = '✅ Verificado';
        }

        function closeModal(event) {
            if (event && event.target !== event.currentTarget) return;
            document.getElementById('content-modal').style.display = 'none';
        }

        // ================================================================
        //  INICIALIZAÇÃO
        // ================================================================
        // já exibe a tela de login por padrão
        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('login-page').classList.remove('hidden');
            document.getElementById('selection-page').classList.add('hidden');
            document.getElementById('schedule-page').classList.add('hidden');
        });
    </script>

</body>
</html>
